Options -Indexes
DirectoryIndex index.php

RewriteEngine On

# если файл или папка существуют — отдаем напрямую
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# всё остальное → Yii
RewriteRule ^ index.php [L,QSA]

# запрет прямого доступа к frm
RewriteRule ^frm(/|$) - [F,L]
