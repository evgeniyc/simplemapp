Options -Indexes
# Сначала ищем стандартный index.php, потом локальный
DirectoryIndex index.php index-local.php

RewriteEngine On
# Убираем привязку к подпапке simplemapp, если сайт в корне public_html
RewriteBase /

# Если файл или папка существуют — не трогаем
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Главное правило: отправляем всё на index.php
# Если его нет, Apache сам попробует index-local.php благодаря DirectoryIndex выше
RewriteRule ^ index.php [L,QSA]

# Если index.php физически отсутствует, можно попробовать так:
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index-local.php [L,QSA]

# Запрет прямого доступа к frm
RewriteRule ^frm(/|$) - [F,L]
