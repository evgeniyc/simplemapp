Options -Indexes

# 1. Указываем приоритет индексных файлов для папок
DirectoryIndex index-local.php index.php

RewriteEngine On

# 2. RewriteBase (лучше оставить автоопределение, если сайт в корне)
# RewriteBase /

# 3. Если файл или папка существуют (картинки, стили) — отдаем их как есть
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. Умное перенаправление для PrettyURL
# Проверяем: если существует index-local.php — шлем на него
RewriteCond %{DOCUMENT_ROOT}/index-local.php -f
RewriteRule ^(.*)$ index-local.php [L,QSA]

# 5. Если локального нет — шлем на стандартный index.php
RewriteCond %{DOCUMENT_ROOT}/index.php -f
RewriteRule ^(.*)$ index.php [L,QSA]
